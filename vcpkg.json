{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "arcdps-mock",
  "version": "0.2.0",
  "dependencies": [
    {
      "name": "arcdps-extension",
      "default-features": false,
      "features": [
        "imgui"
      ]
    },
    "imgui",
    "nlohmann-json"
  ],
  "features": {
    "build-tools": {
      "description": "install dependencies for the tools",
      "dependencies": [
        {
          "name": "imgui",
          "features": [
            "dx11-binding",
            "win32-binding"
          ]
        },
        "magic-enum"
      ]
    }
  },
  "overrides": [
    {
      "name": "arcdps-extension",
      "version": "2.2.0"
    },
    {
      "name": "imgui",
      "version": "1.92.7"
    }
  ]
}
